# Configurazione RAG Locale - Esempio
# Copia questo file in .env e configura per il tuo ambiente

# =========================================================================
# LM Studio Configuration
# =========================================================================
LM_STUDIO__API_BASE=http://localhost:1234/v1
LM_STUDIO__MODEL_NAME=mistral-7b-instruct-v0.3
LM_STUDIO__MAX_TOKENS=1024
LM_STUDIO__TEMPERATURE=0.3
LM_STUDIO__TOP_P=0.9
LM_STUDIO__IDLE_TTL_SECONDS=300
LM_STUDIO__TIMEOUT_SECONDS=120
LM_STUDIO__MAX_RETRIES=3

# =========================================================================
# ChromaDB Configuration
# =========================================================================
CHROMADB__MODE=persistent
CHROMADB__CHUNK_SIZE=1000
CHROMADB__CHUNK_OVERLAP=100
CHROMADB__HNSW_SPACE=cosine
CHROMADB__HNSW_CONSTRUCTION_EF=200
CHROMADB__HNSW_M=16

# =========================================================================
# RAG Engine Configuration
# =========================================================================
RAG__SIMILARITY_TOP_K=5
RAG__ENABLE_HITL=true
RAG__HITL_SCORE_THRESHOLD=0.7

# =========================================================================
# Application Configuration
# =========================================================================
APP__LOG_LEVEL=INFO
APP__ENABLE_MONITORING=true
APP__MEMORY_WARNING_THRESHOLD_PCT=85

# =========================================================================
# NOTE per HP ProBook 440 G11 (16GB RAM, CPU-only):
#
# CRITICAL PARAMETERS:
# - LM_STUDIO__IDLE_TTL_SECONDS: Quando 0, modello rimane caricato.
#   Usa 300 (5 min) per liberare RAM se inattivo.
# - CHROMADB__HNSW_CONSTRUCTION_EF: 200 è ottimale per CPU non-dedicata.
#   Range consigliato: 100-400 (più alto = più accurato ma lento)
# - RAG__SIMILARITY_TOP_K: Aumentare da 5 a 10+ se risultati inaccurati
# - RAG__HITL_SCORE_THRESHOLD: Aumentare (es. 0.8) per essere più conservativi
#
# MEMORY MANAGEMENT:
# Se il sistema rallenta, aumenta HITL_SCORE_THRESHOLD per ridurre
# overhead di retrieval e generazione.
# =========================================================================
